<html>
  <head>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f4f4f5;
        font-family: Arial, sans-serif;
        color: #27272a;
      }
      .container {
        max-width: 620px;
        margin: 24px auto;
        background-color: #ffffff;
        border: 1px solid #e4e4e7;
        border-radius: 12px;
        padding: 36px;
      }
      h1 {
        margin: 0 0 16px;
        color: #09090b;
        font-size: 28px;
        line-height: 1.25;
      }
      p {
        margin: 0 0 14px;
        font-size: 15px;
        line-height: 1.65;
        color: #3f3f46;
      }
      .cta-wrap {
        margin: 26px 0;
      }
      .cta-button {
        display: inline-block;
        padding: 12px 24px;
        text-decoration: none;
        background-color: #111827;
        color: #ffffff !important;
        border-radius: 8px;
        font-weight: 700;
        font-size: 14px;
      }
      .hint-box {
        margin-top: 18px;
        padding: 12px 14px;
        border-radius: 8px;
        border: 1px solid #e4e4e7;
        background-color: #fafafa;
      }
      .mono {
        font-family: Consolas, "Liberation Mono", Menlo, monospace;
        word-break: break-all;
        color: #18181b;
        font-size: 13px;
      }
      .footer {
        margin-top: 28px;
        padding-top: 16px;
        border-top: 1px solid #f1f5f9;
        font-size: 12px;
        color: #71717a;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>You are invited to join {{organizationName}}</h1>

      <p>Hello,</p>
      <p>
        <strong>{{inviterName}}</strong> invited you to collaborate in
        <strong>{{organizationName}}</strong>.
      </p>
      <p>
        Click the button below to open the signup page with your invite pre-attached.
      </p>

      <div class="cta-wrap">
        <a href="{{signupInviteUrl}}" class="cta-button">Sign up and join workspace</a>
      </div>

      <p>This invite expires in 14 days. If this was unexpected, you can safely ignore this email.</p>

      <div class="hint-box">
        <p style="margin: 0 0 6px;"><strong>Invite ID</strong></p>
        <div class="mono">{{inviteToken}}</div>
      </div>

      <div class="footer">
        SAAS Management Platform
      </div>
    </div>
  </body>
</html>
